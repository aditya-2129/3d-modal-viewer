FROM node:20-bullseye

RUN apt-get update && apt-get install -y \
    freecad \
    python3 \
    python3-pip \
    xvfb \
    && pip3 install trimesh \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY package*.json ./
RUN npm install
COPY . .

# Use xvfb-run to provide a virtual display for FreeCAD
CMD ["xvfb-run", "-a", "npm", "run", "worker"]